    "start:client": "npm start --prefix client"
  },
  "dependencies": {
    "concurrently": "^5.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "nodemon": "^2.0.4"
  }
}
